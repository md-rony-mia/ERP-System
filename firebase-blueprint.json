{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An individual retail inventory item or product catalog entry.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "sku": { "type": "string" },
        "category": { "type": "string" },
        "unit": { "type": "string" },
        "warehouse": { "type": "string" },
        "price": { "type": "number" },
        "cost": { "type": "number" },
        "stock": { "type": "number" },
        "alertQty": { "type": "number" }
      },
      "required": ["id", "name", "sku", "price", "cost", "stock"]
    },
    "Customer": {
      "title": "Customer",
      "description": "A customer record managing contact information and outstanding balance details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "group": { "type": "string" },
        "outstandingBalance": { "type": "number" }
      },
      "required": ["id", "name", "outstandingBalance"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "A wholesaler or distributor vendor profile.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "companyName": { "type": "string" },
        "group": { "type": "string" },
        "outstandingBalance": { "type": "number" }
      },
      "required": ["id", "name", "outstandingBalance"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "A completed point-of-sale checkout order.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "invoiceNo": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "date": { "type": "string" },
        "subtotal": { "type": "number" },
        "taxRate": { "type": "number" },
        "taxAmount": { "type": "number" },
        "discount": { "type": "number" },
        "total": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "isPaid": { "type": "boolean" }
      },
      "required": ["id", "invoiceNo", "customerId", "total", "paymentMethod", "isPaid"]
    },
    "PurchaseOrder": {
      "title": "PurchaseOrder",
      "description": "An enterprise purchasing replenishment order placed with a supplier.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "poNo": { "type": "string" },
        "supplierId": { "type": "string" },
        "supplierName": { "type": "string" },
        "date": { "type": "string" },
        "subtotal": { "type": "number" },
        "total": { "type": "number" },
        "status": { "type": "string" }
      },
      "required": ["id", "poNo", "supplierId", "total", "status"]
    },
    "BankAccount": {
      "title": "BankAccount",
      "description": "A financial bank or mobile wallet register.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "accountName": { "type": "string" },
        "accountNumber": { "type": "string" },
        "bankName": { "type": "string" },
        "balance": { "type": "number" },
        "type": { "type": "string" }
      },
      "required": ["id", "accountName", "balance", "type"]
    },
    "Branch": {
      "title": "Branch",
      "description": "An enterprise branch location or outlet.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "branchCode": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "managerName": { "type": "string" },
        "status": { "type": "string" },
        "isMainBranch": { "type": "boolean" },
        "stockMode": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "name", "branchCode", "status", "isMainBranch", "stockMode"]
    },
    "BranchStock": {
      "title": "BranchStock",
      "description": "Specific product inventory count per branch location for independent stock mode.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "branchId": { "type": "string" },
        "productId": { "type": "string" },
        "stock": { "type": "number" },
        "alertQty": { "type": "number" },
        "lastUpdated": { "type": "string" }
      },
      "required": ["id", "branchId", "productId", "stock"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial ledger log tracking monetary deposits and withdrawals.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string" },
        "amount": { "type": "number" },
        "accountId": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["id", "date", "description", "type", "amount", "accountId"]
    },
    "AccountHead": {
      "title": "AccountHead",
      "description": "An account code in the general ledger Chart of Accounts.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "code": { "type": "string" },
        "type": { "type": "string" },
        "balance": { "type": "number" }
      },
      "required": ["id", "name", "code", "type", "balance"]
    },
    "Employee": {
      "title": "Employee",
      "description": "Confidential corporate employee registry document.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "designation": { "type": "string" },
        "department": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "salary": { "type": "number" },
        "status": { "type": "string" }
      },
      "required": ["id", "name", "designation", "salary", "status"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "An employee attendance register record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "employeeId": { "type": "string" },
        "employeeName": { "type": "string" },
        "date": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "employeeId", "date", "status"]
    },
    "LoanAccount": {
      "title": "LoanAccount",
      "description": "Corporate financing or employee credit loan tracker.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "accountNo": { "type": "string" },
        "borrowerName": { "type": "string" },
        "amount": { "type": "number" },
        "outstandingAmount": { "type": "number" },
        "status": { "type": "string" }
      },
      "required": ["id", "accountNo", "borrowerName", "amount", "outstandingAmount", "status"]
    },
    "AppSettings": {
      "title": "AppSettings",
      "description": "General system setup and user list mappings.",
      "type": "object",
      "properties": {
        "companyName": { "type": "string" },
        "companyAddress": { "type": "string" },
        "phone": { "type": "string" },
        "defaultVatRate": { "type": "number" }
      },
      "required": ["companyName", "defaultVatRate"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "Role profile database stored under users collection.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string" }
      },
      "required": ["uid", "role"]
    },
    "ErrorLog": {
      "title": "ErrorLog",
      "description": "System error log entry captured during component crashes or exceptions.",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string" },
        "message": { "type": "string" },
        "stack": { "type": "string" },
        "userId": { "type": "string" },
        "userRole": { "type": "string" },
        "currentTab": { "type": "string" },
        "currentSubTab": { "type": "string" },
        "userAgent": { "type": "string" }
      },
      "required": ["timestamp", "message"]
    }
  },
  "firestore": {
    "/error_logs/{docId}": {
      "schema": "ErrorLog",
      "description": "Captured error logs for Administrator inspection."
    },
    "/settings/{docId}": {
      "schema": "AppSettings",
      "description": "Global enterprise configuration settings."
    },
    "/products/{docId}": {
      "schema": "Product",
      "description": "Catalog of company inventory products."
    },
    "/customers/{docId}": {
      "schema": "Customer",
      "description": "List of active retail and wholesale clients."
    },
    "/suppliers/{docId}": {
      "schema": "Supplier",
      "description": "Wholesalers and parts suppliers."
    },
    "/invoices/{docId}": {
      "schema": "Invoice",
      "description": "Point of sale (POS) receipt records."
    },
    "/purchaseOrders/{docId}": {
      "schema": "PurchaseOrder",
      "description": "Active buying pipeline purchases."
    },
    "/bankAccounts/{docId}": {
      "schema": "BankAccount",
      "description": "Balances of active company financial accounts."
    },
    "/transactions/{docId}": {
      "schema": "Transaction",
      "description": "Logs of cash/ledger movements."
    },
    "/accountHeads/{docId}": {
      "schema": "AccountHead",
      "description": "Chart of ledger accounts."
    },
    "/employees/{docId}": {
      "schema": "Employee",
      "description": "Employee personnel registry data."
    },
    "/attendances/{docId}": {
      "schema": "Attendance",
      "description": "Logs of employee daily shifts."
    },
    "/loanAccounts/{docId}": {
      "schema": "LoanAccount",
      "description": "Tracks corporate disbursals and outstanding interest."
    },
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profiles defining application role claims."
    }
  }
}
