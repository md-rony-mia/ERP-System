rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is authenticated.
    // Every single database operation requires request.auth to be non-null.
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to fetch the authenticated user's role.
    // It first attempts to retrieve the role from the Firebase Auth custom claim token ('request.auth.token.role').
    // If not set, it performs a fallback check against the '/users/{uid}' document in Firestore.
    // Possible roles: 'Administrator', 'Manager', 'Cashier', 'Sales Agent' (matching the system's defined roles).
    function getUserRole() {
      return request.auth.token.role != null 
        ? request.auth.token.role 
        : (exists(/databases/$(database)/documents/users/$(request.auth.uid))
            ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
            : null);
    }

    // Helper check to verify if the authenticated user has either 'Administrator' or 'Manager' clearance level.
    function isAdminOrManager() {
      return isSignedIn() && (
        request.auth.token.email == "ronymia2022@gmail.com" ||
        request.auth.token.email == "tasnim@madani.com" ||
        getUserRole() == 'Administrator' || 
        getUserRole() == 'Manager'
      );
    }

    // Helper check to verify if the authenticated user has any valid job-assigned role.
    // This allows Administrators, Managers, Cashiers, and Sales Agents to perform approved operational actions.
    function isAllowedOperator() {
      return isSignedIn() && (
        request.auth.token.email == "ronymia2022@gmail.com" ||
        request.auth.token.email == "tasnim@madani.com" ||
        request.auth.token.email == "sabbir@madani.com" ||
        request.auth.token.email == "sumona@madani.com" ||
        getUserRole() == 'Administrator' || 
        getUserRole() == 'Manager' || 
        getUserRole() == 'Cashier' || 
        getUserRole() == 'Sales Agent'
      );
    }

    // =========================================================================
    // SECTION A: SENSITIVE ENTERPRISE SYSTEM COLLECTIONS (Admin/Manager ONLY)
    // =========================================================================
    // These collections contain highly confidential data such as staff payroll, general ledgers,
    // tax configurations, and system settings. To prevent unauthorized modifications or privilege
    // escalation, WRITE access is strictly restricted to Administrators and Managers.
    // READ access is granted to all authenticated staff to maintain active operational views.

    // 1. Settings Collection
    // Contains system-wide parameters (VAT, currency, company address, and the authorized usersList).
    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdminOrManager();
    }

    // 2. Account Heads Collection
    // Stores the formal Chart of Accounts (Assets, Liabilities, Equity) and active financial balances.
    match /accountHeads/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdminOrManager();
    }

    // 3. Employees Collection
    // Stores confidential employee records, departments, designations, joining dates, and base salaries.
    match /employees/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdminOrManager();
    }

    // 4. Loan Accounts Collection
    // Stores borrower names, interest rates, disbursals, outstanding balances, and repayment details.
    match /loanAccounts/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdminOrManager();
    }

    // 5. Transactions Collection
    // Stores the system ledger logs tracking all monetary deposit, withdrawal, and transfer events.
    match /transactions/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdminOrManager();
    }

    // 6. Bank Accounts Collection
    // Tracks active corporate banking accounts, wallet balances, and account numbers.
    match /bankAccounts/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdminOrManager();
    }

    // 7. Suppliers Collection
    // Manages wholesale supplier names, corporate groups, and total outstanding payables.
    match /suppliers/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdminOrManager();
    }

    // 8. Purchase Orders (PO) Collection
    // Tracks buying pipelines, PO numbers, items, costs, and received/cancelled statuses.
    match /purchaseOrders/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdminOrManager();
    }

    // 9. Attendances Collection
    // Logs employee attendance registers, clock-in times, clock-out times, and leave statuses.
    match /attendances/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdminOrManager();
    }

    // 10. Users Collection
    // Stores profiles containing roles and metadata for registered staff.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isAdminOrManager();
      allow create: if isSignedIn() && request.auth.uid == uid && (
        (request.auth.token.email == "ronymia2022@gmail.com" && request.resource.data.role == "Administrator") ||
        (request.auth.token.email == "tasnim@madani.com" && request.resource.data.role == "Manager") ||
        (request.auth.token.email == "sabbir@madani.com" && request.resource.data.role == "Cashier") ||
        (request.auth.token.email == "sumona@madani.com" && request.resource.data.role == "Sales Agent") ||
        (!(request.auth.token.email in ["ronymia2022@gmail.com", "tasnim@madani.com", "sabbir@madani.com", "sumona@madani.com"]) && request.resource.data.role == "Sales Agent")
      );
    }


    // =========================================================================
    // SECTION B: KEY OPERATIONAL COLLECTIONS (All Authenticated Staff Roles)
    // =========================================================================
    // These collections handle routine checkout and inventory transactions (sales invoices, customer records, 
    // and products catalog/stock levels). Both Cashier and Sales Agent roles are allowed WRITE access to
    // perform their core job responsibilities.

    // 11. Invoices (POS Checkout) Collection
    // Tracks billing transactions, line items, and payment modes during checkout.
    match /invoices/{docId} {
      allow read: if isSignedIn();
      allow write: if isAllowedOperator();
    }

    // 12. Customers Collection
    // Tracks retail customer data, active groups, and current outstanding credit balance.
    match /customers/{docId} {
      allow read: if isSignedIn();
      allow write: if isAllowedOperator();
    }

    // 13. Products Collection
    // Catalog of sellable goods, containing active SKUs, unit pricing, warehouses, and current physical stock levels.
    match /products/{docId} {
      allow read: if isSignedIn();
      allow write: if isAllowedOperator();
    }


    // =========================================================================
    // SECTION B.2: EXTENDED ENTERPRISE SUBSYSTEM COLLECTIONS
    // =========================================================================
    // Rules covering Manufacturing, Projects, Service, Documents, Workflow and Integration modules.

    // Manufacturing Subsystem
    match /boms/{docId} {
      allow read: if isSignedIn();
      allow write: if isAllowedOperator();
    }
    match /workcenters/{docId} {
      allow read: if isSignedIn();
      allow write: if isAllowedOperator();
    }
    match /productionOrders/{docId} {
      allow read: if isSignedIn();
      allow write: if isAllowedOperator();
    }
    match /qualityInspections/{docId} {
      allow read: if isSignedIn();
      allow write: if isAllowedOperator();
    }

    // Projects Subsystem
    match /projects/{docId} {
      allow read: if isSignedIn();
      allow write: if isAllowedOperator();
    }
    match /projectTasks/{docId} {
      allow read: if isSignedIn();
      allow write: if isAllowedOperator();
    }
    match /projectMilestones/{docId} {
      allow read: if isSignedIn();
      allow write: if isAllowedOperator();
    }
    match /projectTimesheets/{docId} {
      allow read: if isSignedIn();
      allow write: if isAllowedOperator();
    }

    // Service Subsystem
    match /serviceTechnicians/{docId} {
      allow read: if isSignedIn();
      allow write: if isAllowedOperator();
    }
    match /serviceAmcs/{docId} {
      allow read: if isSignedIn();
      allow write: if isAllowedOperator();
    }
    match /serviceWarranties/{docId} {
      allow read: if isSignedIn();
      allow write: if isAllowedOperator();
    }
    match /serviceRepairs/{docId} {
      allow read: if isSignedIn();
      allow write: if isAllowedOperator();
    }
    match /serviceComplaints/{docId} {
      allow read: if isSignedIn();
      allow write: if isAllowedOperator();
    }

    // Documents Subsystem
    match /documents/{docId} {
      allow read: if isSignedIn();
      allow write: if isAllowedOperator();
    }
    match /docContracts/{docId} {
      allow read: if isSignedIn();
      allow write: if isAllowedOperator();
    }

    // Workflow Subsystem
    match /wfRules/{docId} {
      allow read: if isSignedIn();
      allow write: if isAllowedOperator();
    }
    match /wfAutomations/{docId} {
      allow read: if isSignedIn();
      allow write: if isAllowedOperator();
    }
    match /wfPending/{docId} {
      allow read: if isSignedIn();
      allow write: if isAllowedOperator();
    }

    // Integration Subsystem
    match /integrationsWebhooks/{docId} {
      allow read: if isSignedIn();
      allow write: if isAllowedOperator();
    }
    match /integrationsApps/{docId} {
      allow read: if isSignedIn();
      allow write: if isAllowedOperator();
    }
    match /integrationGithub/{docId} {
      allow read: if isSignedIn();
      allow write: if isAllowedOperator();
    }
    match /integrationGithubLogs/{docId} {
      allow read: if isSignedIn();
      allow write: if isAllowedOperator();
    }

    // CRM Subsystem
    match /leads/{docId} {
      allow read: if isSignedIn();
      allow write: if isAllowedOperator();
    }
    match /campaigns/{docId} {
      allow read: if isSignedIn();
      allow write: if isAllowedOperator();
    }
    match /crmActivities/{docId} {
      allow read: if isSignedIn();
      allow write: if isAllowedOperator();
    }

    // Fixed Assets Subsystem
    match /assets/{docId} {
      allow read: if isSignedIn();
      allow write: if isAllowedOperator();
    }


    // =========================================================================
    // SECTION C: FALLBACK SAFETY NET
    // =========================================================================
    // An absolute deny-all fallback rule protecting the database from any queries
    // targeting unmapped collections or paths, implementing a robust zero-trust defense.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
